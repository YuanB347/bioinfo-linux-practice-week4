x <- seq(-10, 10, by = 0.1)
curve_data <- data.frame(
x = rep(x, 3),
y = c(
dnorm(x, mean = 0, sd = 1),
dnorm(x, mean = 2, sd = 1),
dnorm(x, mean = 0, sd = 2)
),
group = factor(rep(c("mean=0, sd=1", "mean=2, sd=1", "mean=0, sd=2"),
each = length(x)))
)
ggplot(curve_data, aes(x = x, y = y, color = group)) +
geom_line(linewidth = 1) +
labs(
title = "Normal Curves with Different Means and SDs",
x = "x",
y = "Density",
color = "Curve Type"
) +
theme_minimal()
