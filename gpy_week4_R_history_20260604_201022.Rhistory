my_summary <- function(x, print = FALSE) {
result <- list(
n = length(x),
mean = mean(x),
sd = sd(x),
median = median(x),
min = min(x),
max = max(x)
)
if (print) {
cat("n =", result$n, "\n")
cat("mean =", result$mean, "\n")
cat("sd =", result$sd, "\n")
cat("median =", result$median, "\n")
cat("min =", result$min, "\n")
cat("max =", result$max, "\n")
}
return(result)
}
test_x <- c(3, 5, 7, 8, 10, 12, 15)
my_summary(test_x, print = TRUE)
