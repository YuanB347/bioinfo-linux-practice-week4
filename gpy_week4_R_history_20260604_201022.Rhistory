# 创建宽格式数据
data_wide <- data.frame(
ID = c("AU", "CN", "PRK"),
Country = c("Australia", "China", "North Korea"),
LExp1990 = c(76.9, 69.3, 69.9),
LExp2000 = c(79.6, 72.0, 65.3),
LExp2010 = c(82.0, 75.2, 69.6)
)
data_wide
# 使用 gather() 转成长格式
data_long <- gather(
data_wide,
key = "Variable",
value = "Life_Exp",
c(LExp1990, LExp2000, LExp2010)
)
data_long
# 使用 spread() 转回宽格式
data_wide_again <- spread(data_long, key = Variable, value = Life_Exp)
data_wide_again
# 恢复显示位数
options(digits = 3)
# 以 cyl 和 gear 分组，对 mtcars 所有变量求均值
aggdata1 <- aggregate(
mtcars,
by = list(mtcars$cyl, mtcars$gear),
FUN = mean,
na.rm = TRUE
)
aggdata1
# 改进版：去掉 cyl 和 carb 两列，并给分组变量命名
aggdata2 <- aggregate(
mtcars[-c(2, 10)],
by = list(Cylinders = mtcars$cyl, Gears = mtcars$gear),
FUN = mean,
na.rm = TRUE
)
aggdata2
# 按 cyl 和 gear 分组，对所有变量计算均值
mtcars %>%
group_by(cyl, gear) %>%
summarise_all(list(mean), na.rm = TRUE)
mtcars %>%
group_by(cyl, gear) %>%
summarise(across(everything(), mean, na.rm = TRUE), .groups = "drop")
