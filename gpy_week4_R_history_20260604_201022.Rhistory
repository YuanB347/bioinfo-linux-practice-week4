feelings <- c("sad", "afraid")
# 根据不同情绪返回不同文本
for (i in feelings) {
print(
switch(i,
happy  = "I am glad you are happy",
afraid = "There is nothing to fear",
sad    = "Cheer up",
angry  = "Calm down now"
)
)
}
# 定义一个函数：
# parametric = TRUE 时返回均值和标准差
# parametric = FALSE 时返回中位数和 MAD
# print = TRUE 时打印结果
mystats <- function(x, parametric = TRUE, print = FALSE) {
if (parametric) {
center <- mean(x)
spread <- sd(x)
} else {
center <- median(x)
spread <- mad(x)
}
if (print & parametric) {
cat("Mean =", center, "\n", "SD =", spread, "\n")
} else if (print & !parametric) {
cat("Median =", center, "\n", "MAD =", spread, "\n")
}
result <- list(center = center, spread = spread)
return(result)
}
# 测试函数
set.seed(1234)
x_stats <- rnorm(500)
# 返回结果但不打印
y_stats <- mystats(x_stats)
y_stats
# 参数统计版本并打印
mystats(x_stats, parametric = TRUE, print = TRUE)
# 非参数统计版本并打印
mystats(x_stats, parametric = FALSE, print = TRUE)
