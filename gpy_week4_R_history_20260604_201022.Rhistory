library(MultiRNG)
library(tidyr)
library(dplyr)
# 设置输出显示的小数位数
options(digits = 3)
# 创建一个数值向量
x <- c(1, 2, 3, 4, 5, 6, 7, 8)
# 直接用内置函数计算均值和标准差
mean(x)
sd(x)
# 手动计算均值和标准差
n <- length(x)                    # 样本个数
meanx <- sum(x) / n               # 均值
css <- sum((x - meanx)^2)         # 离均差平方和
sdx <- sqrt(css / (n - 1))        # 样本标准差
# 查看手动计算结果
meanx
sdx
# 生成从 -3 到 3 的序列
x_curve <- seq(from = -3, to = 3, by = 0.1)
# 计算标准正态分布在各点的密度值
y_curve <- dnorm(x_curve)
# 组合成数据框
normal_data <- data.frame(x = x_curve, y = y_curve)
# 绘图：正态分布密度曲线
ggplot(normal_data, aes(x, y)) +
geom_line() +
labs(
x = "Normal Deviate",
y = "Density"
) +
scale_x_continuous(breaks = seq(-3, 3, 1))
