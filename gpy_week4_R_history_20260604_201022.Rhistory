cat("练习16：\n")
cat("基础 R 与 dplyr 的计算结果应一致，主要差异在写法和可读性。\n\n")
set.seed(100)
student_data <- data.frame(
name = c("Amy Lee", "Ben Wang", "Cathy Lin", "Daniel Wu", "Eva Sun",
"Frank Gu", "Grace He", "Henry Xu"),
math = sample(60:100, 8),
english = sample(65:98, 8),
programming = sample(55:100, 8),
stringsAsFactors = FALSE
)
student_data
# 标准化三门课成绩
z_student <- scale(student_data[, 2:4])
# 综合分数
student_data$overall_z <- apply(z_student, 1, mean)
# 划分等级
cut_points <- quantile(student_data$overall_z, c(0.75, 0.5, 0.25))
student_data$grade <- NA
student_data$grade[student_data$overall_z >= cut_points[1]] <- "A"
student_data$grade[student_data$overall_z < cut_points[1] &
student_data$overall_z >= cut_points[2]] <- "B"
student_data$grade[student_data$overall_z < cut_points[2] &
student_data$overall_z >= cut_points[3]] <- "C"
student_data$grade[student_data$overall_z < cut_points[3]] <- "D"
# 拆分姓名
split_name <- strsplit(student_data$name, " ")
student_data$first_name <- sapply(split_name, "[", 1)
student_data$last_name  <- sapply(split_name, "[", 2)
# 排序
student_data <- student_data[order(student_data$last_name, student_data$first_name), ]
student_data
# 统计每个等级人数
table(student_data$grade)
# 计算每门课均值
colMeans(student_data[, 2:4])
cat("练习17：\n")
cat("这个练习把标准化、apply、quantile、strsplit、order 都串联起来了。\n\n")
student_long <- gather(
student_data,
key = "subject",
value = "score",
math, english, programming
)
student_long
# 简单可视化：不同科目的成绩分布
ggplot(student_long, aes(x = subject, y = score, fill = subject)) +
geom_boxplot() +
labs(
title = "Score Distribution by Subject",
x = "Subject",
y = "Score"
) +
theme_minimal()
student_long %>%
group_by(subject) %>%
summarise(
mean_score = mean(score),
sd_score = sd(score),
min_score = min(score),
max_score = max(score),
.groups = "drop"
)
