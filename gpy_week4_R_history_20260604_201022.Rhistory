library(ggplot2)
library(tidyr)
library(dplyr)
scores <- c(68, 72, 75, 80, 81, 85, 88, 90, 91, 95)
# 直接计算
mean(scores)
sd(scores)
min(scores)
max(scores)
range(scores)
# 手动验证均值和标准差
n <- length(scores)
mean_manual <- sum(scores) / n
css_manual <- sum((scores - mean_manual)^2)
sd_manual <- sqrt(css_manual / (n - 1))
mean_manual
sd_manual
# 变异系数 = 标准差 / 均值
cv <- sd(scores) / mean(scores)
cv
# 小结性输出
cat("练习1：\n")
cat("均值 =", mean(scores), "\n")
cat("标准差 =", sd(scores), "\n")
cat("极差 =", diff(range(scores)), "\n")
cat("变异系数 =", cv, "\n\n")
group_a <- c(78, 79, 80, 81, 82)
group_b <- c(60, 70, 80, 90, 100)
mean(group_a)
mean(group_b)
sd(group_a)
sd(group_b)
result_compare <- data.frame(
group = c("A", "B"),
mean = c(mean(group_a), mean(group_b)),
sd = c(sd(group_a), sd(group_b))
)
result_compare
