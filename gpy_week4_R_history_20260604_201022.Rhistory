# 构造一个 6 行矩阵，共 30 个标准正态随机数
mydata_apply <- matrix(rnorm(30), nrow = 6)
mydata_apply
# 对每一行求均值（MARGIN = 1 表示按行）
apply(mydata_apply, 1, mean)
# 对每一列求均值（MARGIN = 2 表示按列）
apply(mydata_apply, 2, mean)
# 对每一列求截尾均值
